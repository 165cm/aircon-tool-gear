---
import { SITE, NAV_ITEMS } from '../consts';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const homeHref = `${base}/`;
const navHref = (href: string) => `${base}${href}`;
---
<header class="border-b border-slate-200 bg-white">
  <div class="mx-auto flex max-w-5xl items-center justify-between px-4 py-3 md:py-4">
    <a href={homeHref} class="text-base font-bold tracking-tight text-slate-900 md:text-lg">
      {SITE.name}
    </a>
    <nav>
      <ul class="hidden gap-5 md:flex">
        {NAV_ITEMS.map((item) => (
          <li>
            <a href={navHref(item.href)} class="text-sm text-slate-700 transition hover:text-orange-600">
              {item.label}
            </a>
          </li>
        ))}
      </ul>
    </nav>
  </div>
</header>
