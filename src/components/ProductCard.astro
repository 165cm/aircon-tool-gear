---
import { CATEGORY_LABEL, getProductImageUrl, type Product } from '../data/products';
import AmazonLink from './AmazonLink.astro';

interface Props {
  product: Product;
  pageType: string;
  linkPosition?: string;
}

const { product, pageType, linkPosition = 'product-card' } = Astro.props;
const itemName = `${product.brand} ${product.name}`;
---
<article class="overflow-hidden rounded-lg border border-slate-200 bg-white shadow-sm">
  {product.asin ? (
    <AmazonLink
      search={product.amazonSearch}
      itemId={product.slug}
      itemName={itemName}
      pageType={pageType}
      linkPosition={`${linkPosition}-image`}
      variant="wrapper"
      class="flex h-44 items-center justify-center bg-white p-4"
    >
      <img
        src={getProductImageUrl(product.asin)}
        alt={itemName}
        width="320"
        height="320"
        loading="lazy"
        decoding="async"
        class="max-h-36 w-auto object-contain"
      />
    </AmazonLink>
  ) : (
    <div class="flex h-44 items-center justify-center bg-slate-100 text-xs text-slate-400">
      画像準備中
    </div>
  )}

  <div class="p-5">
    <div class="flex items-center gap-2 text-xs text-slate-500">
      <span class="rounded bg-slate-100 px-2 py-0.5 font-medium text-slate-700">{CATEGORY_LABEL[product.category]}</span>
      <span>{product.priceBand}</span>
    </div>
    <h3 class="mt-2 text-base font-semibold text-slate-900 md:text-lg">
      {itemName}
    </h3>
    <p class="mt-2 text-sm leading-relaxed text-slate-700">{product.summary}</p>

    <dl class="mt-3 space-y-1 text-xs text-slate-600">
      <div>
        <dt class="inline font-semibold text-slate-700">向いている使い方:</dt>
        <dd class="inline"> {product.bestFor}</dd>
      </div>
      {product.cautions.length > 0 && (
        <div>
          <dt class="inline font-semibold text-slate-700">購入前の注意:</dt>
          <dd class="inline"> {product.cautions.join('／')}</dd>
        </div>
      )}
    </dl>

    <div class="mt-4">
      <AmazonLink
        search={product.amazonSearch}
        itemId={product.slug}
        itemName={itemName}
        pageType={pageType}
        linkPosition={linkPosition}
        variant="button"
      />
    </div>
  </div>
</article>
