---
import BaseLayout from '../layouts/BaseLayout.astro';
import ArticleCard from '../components/ArticleCard.astro';
import { getCollection } from 'astro:content';
import { CATEGORY_LABEL, CATEGORY_DESCRIPTION } from '../content.config';

const CATEGORY = 'energy-saving' as const;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const posts = (await getCollection('posts', (entry) => entry.data.category === CATEGORY)).sort(
  (a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf(),
);
---
<BaseLayout title={CATEGORY_LABEL[CATEGORY]} description={CATEGORY_DESCRIPTION[CATEGORY]}>
  <h1 class="text-2xl font-bold text-slate-900 md:text-3xl">{CATEGORY_LABEL[CATEGORY]}</h1>
  <p class="mt-3 text-sm leading-relaxed text-slate-700 md:text-base">
    {CATEGORY_DESCRIPTION[CATEGORY]}
  </p>

  {posts.length === 0 ? (
    <p class="mt-8 rounded-lg border border-amber-200 bg-amber-50 p-4 text-sm text-amber-900">
      このカテゴリの記事は順次公開予定です。
    </p>
  ) : (
    <div class="mt-8 grid gap-4 md:grid-cols-2">
      {posts.map((post) => (
        <ArticleCard
          href={`${base}/posts/${post.id}/`}
          title={post.data.title}
          description={post.data.description}
          category={post.data.category}
          publishDate={post.data.publishDate}
        />
      ))}
    </div>
  )}

  <section class="mt-12 rounded-lg border border-slate-200 bg-white p-6">
    <h2 class="text-lg font-semibold text-slate-900">節電の優先順位</h2>
    <ol class="mt-3 list-decimal space-y-1 pl-5 text-sm leading-relaxed text-slate-700">
      <li>フィルター掃除（2週〜1か月に1回）</li>
      <li>設定温度を1℃緩める（冷房+1℃、暖房−1℃で約10%削減）</li>
      <li>サーキュレーターで気流を作る（設定温度をいじらず体感温度を上げる/下げる）</li>
      <li>カーテン・ブラインドで日射遮蔽</li>
      <li>こまめなON/OFFよりつけっぱなしの方が有利な場面を理解する</li>
    </ol>
  </section>
</BaseLayout>
