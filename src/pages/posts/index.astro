---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ArticleCard from '../../components/ArticleCard.astro';
import { getCollection } from 'astro:content';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const posts = (await getCollection('posts')).sort(
  (a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf(),
);
---
<BaseLayout title="記事一覧" description="エアコン助かるラボの最新記事一覧。症状・畳数・節電・カビ臭い対策のカテゴリ別に整理しています。">
  <h1 class="text-2xl font-bold text-slate-900 md:text-3xl">記事一覧</h1>
  <p class="mt-3 text-sm leading-relaxed text-slate-700 md:text-base">
    最新の記事から順に並べています。カテゴリで絞り込みたい場合は、各カテゴリページへ移動してください。
  </p>

  {posts.length === 0 ? (
    <p class="mt-8 rounded-lg border border-amber-200 bg-amber-50 p-4 text-sm text-amber-900">
      記事は順次公開予定です。
    </p>
  ) : (
    <div class="mt-8 grid gap-4 md:grid-cols-2">
      {posts.map((post) => (
        <ArticleCard
          href={`${base}/posts/${post.id}/`}
          title={post.data.title}
          description={post.data.description}
          category={post.data.category}
          publishDate={post.data.publishDate}
        />
      ))}
    </div>
  )}
</BaseLayout>
