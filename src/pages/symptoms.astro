---
import BaseLayout from '../layouts/BaseLayout.astro';
import ArticleCard from '../components/ArticleCard.astro';
import { getCollection } from 'astro:content';
import { CATEGORY_LABEL, CATEGORY_DESCRIPTION } from '../content.config';

const CATEGORY = 'symptoms' as const;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const posts = (await getCollection('posts', (entry) => entry.data.category === CATEGORY)).sort(
  (a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf(),
);
---
<BaseLayout title={CATEGORY_LABEL[CATEGORY]} description={CATEGORY_DESCRIPTION[CATEGORY]}>
  <h1 class="text-2xl font-bold text-slate-900 md:text-3xl">{CATEGORY_LABEL[CATEGORY]}</h1>
  <p class="mt-3 text-sm leading-relaxed text-slate-700 md:text-base">
    {CATEGORY_DESCRIPTION[CATEGORY]}
  </p>

  {posts.length === 0 ? (
    <p class="mt-8 rounded-lg border border-amber-200 bg-amber-50 p-4 text-sm text-amber-900">
      このカテゴリの記事は順次公開予定です。
    </p>
  ) : (
    <div class="mt-8 grid gap-4 md:grid-cols-2">
      {posts.map((post) => (
        <ArticleCard
          href={`${base}/posts/${post.id}/`}
          title={post.data.title}
          description={post.data.description}
          category={post.data.category}
          publishDate={post.data.publishDate}
        />
      ))}
    </div>
  )}

  <section class="mt-12 rounded-lg border border-slate-200 bg-white p-6">
    <h2 class="text-lg font-semibold text-slate-900">業者を呼ぶ判断の目安</h2>
    <ul class="mt-3 space-y-2 text-sm leading-relaxed text-slate-700">
      <li>・冷媒（ガス）漏れが疑われる（霜・油じみ・効きが極端に悪い）</li>
      <li>・室内機内部から水が大量にあふれる、分解しないと届かない</li>
      <li>・電源を入れるとブレーカーが落ちる、焦げ臭い、煙が出る</li>
      <li>・室外機からの異音・振動が長期化している</li>
      <li>・購入から10年以上経過、修理費が買い替え費の半分を超える</li>
    </ul>
    <p class="mt-3 text-xs text-slate-500">上記に該当する場合、家庭での対処をせず、メーカー修理窓口・電気工事業者・量販店の長期保証窓口へご相談ください。</p>
  </section>
</BaseLayout>
