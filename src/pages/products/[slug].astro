---
import BaseLayout from '../../layouts/BaseLayout.astro';
import AmazonLink from '../../components/AmazonLink.astro';
import { CATEGORY_LABEL, PRODUCTS, getProductImageUrl, type Product } from '../../data/products';

export function getStaticPaths() {
  return PRODUCTS.map((product) => ({
    params: { slug: product.slug },
    props: { product },
  }));
}

const { product } = Astro.props as { product: Product };
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const description = `${product.brand} ${product.name}の特徴、向いている使い方、購入前に確認したい注意点を整理しました。`;
---
<BaseLayout title={`${product.brand} ${product.name}`} description={description} showPrBadge>
  <nav class="text-xs text-slate-500">
    <a href={`${base}/`} class="hover:text-orange-600">ホーム</a>
    <span class="mx-1">/</span>
    <span>{CATEGORY_LABEL[product.category]}</span>
    <span class="mx-1">/</span>
    <span>{product.name}</span>
  </nav>

  <header class="mt-4">
    <div class="flex flex-wrap items-center gap-2 text-xs text-slate-500">
      <span class="rounded bg-slate-100 px-2 py-0.5 font-medium text-slate-700">{CATEGORY_LABEL[product.category]}</span>
      <span>価格帯目安: {product.priceBand}</span>
    </div>
    <h1 class="mt-3 text-2xl font-bold text-slate-900 md:text-3xl">{product.brand} {product.name}</h1>
    <p class="mt-3 text-sm leading-relaxed text-slate-700 md:text-base">{product.summary}</p>
  </header>

  {product.asin ? (
    <AmazonLink
      search={product.amazonSearch}
      itemId={product.slug}
      itemName={`${product.brand} ${product.name}`}
      pageType="product"
      linkPosition="hero-image"
      variant="wrapper"
      class="mt-6 flex h-72 items-center justify-center rounded-lg border border-slate-200 bg-white p-6"
    >
      <img
        src={getProductImageUrl(product.asin)}
        alt={`${product.brand} ${product.name}`}
        width="480"
        height="480"
        loading="eager"
        decoding="async"
        class="max-h-60 w-auto object-contain"
      />
    </AmazonLink>
  ) : (
    <div class="mt-6 flex h-44 items-center justify-center rounded-lg border border-slate-200 bg-slate-100 text-xs text-slate-400">
      画像準備中
    </div>
  )}

  <section class="mt-6 flex flex-col gap-3 rounded-lg border border-slate-200 bg-white p-5 md:flex-row md:items-center md:justify-between">
    <div>
      <p class="text-sm font-semibold text-slate-900">価格・在庫を確認</p>
      <p class="text-xs text-slate-500">価格・在庫は変動するため、購入前に必ずご確認ください。</p>
    </div>
    <AmazonLink
      search={product.amazonSearch}
      itemId={product.slug}
      itemName={`${product.brand} ${product.name}`}
      pageType="product"
      linkPosition="hero"
      variant="button"
    />
  </section>

  <section class="mt-8 rounded-lg border border-slate-200 bg-white p-6">
    <h2 class="text-lg font-semibold text-slate-900">向いている使い方</h2>
    <p class="mt-2 text-sm leading-relaxed text-slate-700">{product.bestFor}</p>
  </section>

  {product.cautions.length > 0 && (
    <section class="mt-6 rounded-lg border border-amber-200 bg-amber-50 p-6">
      <h2 class="text-lg font-semibold text-amber-900">購入前に確認したい注意点</h2>
      <ul class="mt-2 list-disc space-y-1 pl-5 text-sm leading-relaxed text-amber-900">
        {product.cautions.map((caution) => <li>{caution}</li>)}
      </ul>
    </section>
  )}

  <section class="mt-8 flex flex-col gap-3 rounded-lg border border-slate-200 bg-white p-5 md:flex-row md:items-center md:justify-between">
    <p class="text-sm text-slate-700">最新の価格・在庫・ユーザーレビューはAmazon商品ページで確認できます。</p>
    <AmazonLink
      search={product.amazonSearch}
      itemId={product.slug}
      itemName={`${product.brand} ${product.name}`}
      pageType="product"
      linkPosition="bottom"
      variant="button"
    />
  </section>
</BaseLayout>
